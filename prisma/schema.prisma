generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("client")
  tenantId      String?
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Tenant {
  id                  String                 @id @default(cuid())
  slug                String                 @unique
  name                String
  domain              String?
  themePrimaryColor   String                 @default("#000000")
  themeSecondaryColor String                 @default("#ffffff")
  themeFont           String                 @default("Inter")
  logoUrl             String?
  active              Boolean                @default(true)
  languages           String[]               @default(["pt"])
  defaultLang         String                 @default("pt")
  users               User[]
  sections            Section[]
  events              SiteEvent[]
  subscribers         NewsletterSubscriber[]
  services            ServicePage[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Section {
  id          String         @id @default(cuid())
  tenantId    String
  sectionKey  String
  label       String
  sectionType String
  position    Int            @default(0)
  visible     Boolean        @default(true)
  content     Json           @default("{}")
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields      SectionField[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, sectionKey])
}

model SectionField {
  id          String   @id @default(cuid())
  sectionId   String
  key         String
  label       String
  type        String
  translatable Boolean @default(true)
  placeholder String?
  helpText    String?
  required    Boolean  @default(false)
  position    Int      @default(0)
  options     Json?
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sectionId, key])
}

model SiteEvent {
  id               String        @id @default(cuid())
  tenantId         String
  slug             String
  title            String
  description      String?       @db.Text
  eventDate        DateTime?
  location         String?
  coverImageUrl    String?
  registrationOpen Boolean       @default(false)
  collectSignups   Boolean       @default(false)
  formSchema       Json          @default("[]")
  signups          EventSignup[]
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([tenantId, slug])
}

model EventSignup {
  id        String    @id @default(cuid())
  eventId   String
  name      String?
  email     String?
  phone     String?
  responses Json      @default("{}")
  event     SiteEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String?
  active    Boolean  @default(true)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([tenantId, email])
}

model ServicePage {
  id            String   @id @default(cuid())
  tenantId      String
  slug          String
  position      Int      @default(0)
  visible       Boolean  @default(true)
  hasDetailPage Boolean  @default(false)
  cardContent   Json     @default("{}")
  detailContent Json     @default("{}")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, slug])
}
